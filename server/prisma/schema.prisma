generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  auctions    Auction[] @relation("SellerAuctions")
  bids        Bid[]
  wonAuctions Auction[] @relation("WonAuctions")
}

model Auction {
  id            Int      @id @default(autoincrement())
  title         String
  startingPrice Float
  currentPrice  Float    @default(0)
  status        String   @default("ACTIVE")
  endTime       DateTime
  createdAt     DateTime @default(now())
  winnerId      Int?
  sellerId      Int
  seller        User     @relation("SellerAuctions", fields: [sellerId], references: [id])
  winner        User?    @relation("WonAuctions", fields: [winnerId], references: [id])
  bids          Bid[]
}

model Bid {
  id        Int     @id @default(autoincrement())
  amount    Float
  auctionId Int
  userId    Int

  auction   Auction @relation(fields: [auctionId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
}